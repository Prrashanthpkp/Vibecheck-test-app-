rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuth() { return request.auth != null; }
    function isOwner(uid) { return request.auth.uid == uid; }
    function isVerified() { return request.auth.token.email_verified; }

    match /users/{uid} {
      allow read: if isAuth();
      allow create: if isOwner(uid) && isVerified();
      allow update: if isOwner(uid)
        && request.resource.data.keys().hasOnly([
           "displayName","username","photoURL","updatedAt",
           "pollCount","voteCount"]);
      allow delete: if isOwner(uid);
    }

    match /usernames/{username} {
      allow read: if isAuth();
      allow create: if isAuth()
        && request.resource.data.uid == request.auth.uid;
      allow delete: if isAuth()
        && resource.data.uid == request.auth.uid;
    }

    match /polls/{pollId} {
      allow read: if isAuth();
      allow create: if isAuth()
        && request.resource.data.authorUid == request.auth.uid
        && request.resource.data.question is string
        && request.resource.data.question.size() >= 1
        && request.resource.data.question.size() <= 150
        && request.resource.data.options is list
        && request.resource.data.options.size() >= 2
        && request.resource.data.options.size() <= 4;
      allow update: if isOwner(resource.data.authorUid)
        || (isAuth()
          && request.resource.data.diff(resource.data)
             .affectedKeys().hasOnly(["totalVotes","voteCounts"]));
      allow delete: if isOwner(resource.data.authorUid);

      match /votes/{voterId} {
        allow read: if isAuth();
        allow create: if isAuth()
          && request.auth.uid == voterId;
        allow update: if isAuth()
          && request.auth.uid == voterId;
        allow delete: if false;
      }
    }

    match /reports/{reportId} {
      allow create: if isAuth()
        && request.resource.data.reporterUid == request.auth.uid;
      allow read, update, delete: if false;
    }
  }
}